---
type Article = {
  url?: string;
  title?: string;
  title_cn?: string;
  authors?: string;
  abstract?: string;
  abstract_cn?: string;
};

type JournalData = {
  journal_key: string;
  journal_full_name: string;
  report_header?: string;
  update_time?: string;
  articles: Article[];
};

interface Props {
  journal: JournalData;
  active?: boolean;
}

const { journal, active = false } = Astro.props;

const missingAbstract = (value: string | undefined) => {
  const text = (value || "").trim();
  return (
    !text ||
    text === "PENDING_LOCAL_FETCH" ||
    text.includes("摘要未找到") ||
    text.includes("摘要不可用") ||
    text.toLowerCase().includes("abstract not found") ||
    text.toLowerCase().includes("not available")
  );
};

const normalizedAbstract = (value: string | undefined, fallback: string) => (missingAbstract(value) ? fallback : value);
const articleCount = journal.articles.length;
const panelId = `panel-${journal.journal_key.toLowerCase()}`;
---

<section
  id={panelId}
  class="journal-panel"
  data-journal-panel
  data-journal-key={journal.journal_key}
  aria-labelledby={`tab-${journal.journal_key.toLowerCase()}`}
  hidden={!active}
>
  <div class="journal-summary">
    <p class="eyebrow">{journal.journal_key}</p>
    <h2>{journal.journal_full_name}</h2>
    <p class="issue-title">{journal.report_header || "最新一期"} · {articleCount} 篇研究论文</p>
    <p class="update-time">更新：{journal.update_time || "尚未记录"}</p>
  </div>

  <p class="search-empty" data-search-empty hidden>没有匹配当前检索条件的文章。</p>

  <div class="article-list">
    {
      journal.articles.map((article, index) => {
        const englishAbstract = normalizedAbstract(article.abstract, "暂无英文摘要。");
        const chineseAbstract = normalizedAbstract(article.abstract_cn, "暂无中文摘要。");
        const searchText = [
          article.title,
          article.title_cn,
          article.authors,
          article.abstract,
          article.abstract_cn,
          journal.journal_key,
          journal.journal_full_name,
        ]
          .join(" ")
          .toLocaleLowerCase();

        return (
          <article class="article-card" data-article-card data-search={searchText}>
            <div class="article-card__header">
              <span class="article-index">{index + 1}</span>
              <div class="article-heading">
                <h3>{article.title || "Untitled"}</h3>
                {article.title_cn && <p class="title-cn">{article.title_cn}</p>}
                <div class="article-meta-row">
                  <p class="authors">{article.authors || "Authors unavailable"}</p>
                  {article.url && (
                    <a class="paper-link" href={article.url} target="_blank" rel="noreferrer noopener">
                      阅读原文
                    </a>
                  )}
                </div>
              </div>
            </div>

            <div class="abstract-grid">
              <section class="abstract-block">
                <h4>中文摘要{missingAbstract(article.abstract) && <span class="status-badge">待补全</span>}</h4>
                <p>{chineseAbstract}</p>
              </section>
              <section class="abstract-block abstract-block--en">
                <h4>Abstract</h4>
                <p>{englishAbstract}</p>
              </section>
            </div>

          </article>
        );
      })
    }
  </div>
</section>
