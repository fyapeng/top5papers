---
import Layout from "../components/Layout.astro";
import JournalPanel from "../components/JournalPanel.astro";
import aer from "../../AER.json";
import jpe from "../../JPE.json";
import qje from "../../QJE.json";
import res from "../../RES.json";
import ecta from "../../ECTA.json";

type Article = {
  title?: string;
  authors?: string;
  abstract?: string;
};

type JournalData = {
  journal_key: string;
  journal_full_name: string;
  report_header?: string;
  update_time?: string;
  articles: Article[];
};

const nonResearchTitlePattern =
  /front\s*matter|frontmatter|back\s*matter|backmatter|\brecent referees\b|acknowledg(?:e)?ment of referees|turnaround times|\breport of the|annual report|\bnobel lecture\b|fisher.?schultz lecture|^comment on\b|: comment$|\ba comment$|^reply to comments?|^correction to:|\berratum\b/i;

const shouldKeepArticle = (article: Article) => {
  const title = article.title || "";
  return !nonResearchTitlePattern.test(title);
};

const sourceJournals = [aer, jpe, qje, res, ecta] as JournalData[];
const journals = sourceJournals.map((journal) => ({
  ...journal,
  articles: journal.articles.filter(shouldKeepArticle),
}));

const formatDateTime = (value: string | undefined) => {
  if (!value) return "尚未更新";
  const normalized = value.endsWith("UTC") ? value.replace(" UTC", "Z") : value;
  const date = new Date(normalized);
  if (Number.isNaN(date.valueOf())) return value;
  return new Intl.DateTimeFormat("zh-CN", {
    dateStyle: "medium",
    timeStyle: "short",
    timeZone: "Asia/Shanghai",
  }).format(date);
};

const latestUpdate = journals
  .map((journal) => journal.update_time)
  .filter(Boolean)
  .sort()
  .at(-1);
---

<Layout>
  <main>
    <section class="page-heading">
      <p class="eyebrow">Top 5 Economics Journals</p>
      <h1>最新论文</h1>
      <p>AER / JPE / QJE / RES / Econometrica · 更新：{formatDateTime(latestUpdate)}</p>
    </section>

    <section class="journal-workspace" aria-label="期刊论文列表">
      <div class="toolbar">
        <div class="journal-tabs" role="tablist" aria-label="选择期刊">
          {
            journals.map((journal, index) => (
              <button
                id={`tab-${journal.journal_key.toLowerCase()}`}
                class:list={["journal-tab", { active: index === 0 }]}
                type="button"
                role="tab"
                aria-selected={index === 0 ? "true" : "false"}
                aria-controls={`panel-${journal.journal_key.toLowerCase()}`}
                data-tab-target={journal.journal_key}
              >
                {journal.journal_key}
              </button>
            ))
          }
        </div>

        <label class="search-field">
          <span>检索</span>
          <input id="article-search" type="search" autocomplete="off" placeholder="标题、作者、摘要关键词" />
        </label>
      </div>

      {journals.map((journal, index) => <JournalPanel journal={journal} active={index === 0} />)}
    </section>
  </main>

  <script is:inline>
    const tabs = Array.from(document.querySelectorAll("[data-tab-target]"));
    const panels = Array.from(document.querySelectorAll("[data-journal-panel]"));
    const searchInput = document.querySelector("#article-search");

    const activePanel = () => panels.find((panel) => !panel.hidden);

    const applySearch = () => {
      const panel = activePanel();
      if (!panel || !searchInput) return;

      const query = searchInput.value.trim().toLocaleLowerCase();
      const cards = Array.from(panel.querySelectorAll("[data-article-card]"));
      let visibleCount = 0;

      for (const card of cards) {
        const text = card.getAttribute("data-search") || "";
        const visible = !query || text.includes(query);
        card.hidden = !visible;
        if (visible) visibleCount += 1;
      }

      const empty = panel.querySelector("[data-search-empty]");
      if (empty) empty.hidden = visibleCount > 0;
    };

    const activateJournal = (key, updateHash = true) => {
      for (const tab of tabs) {
        const active = tab.getAttribute("data-tab-target") === key;
        tab.classList.toggle("active", active);
        tab.setAttribute("aria-selected", active ? "true" : "false");
      }

      for (const panel of panels) {
        panel.hidden = panel.getAttribute("data-journal-key") !== key;
      }

      if (searchInput) searchInput.value = "";
      applySearch();

      if (updateHash) {
        history.replaceState(null, "", `#${key.toLowerCase()}`);
      }
    };

    for (const tab of tabs) {
      tab.addEventListener("click", () => activateJournal(tab.getAttribute("data-tab-target")));
      tab.addEventListener("keydown", (event) => {
        if (!["ArrowLeft", "ArrowRight"].includes(event.key)) return;
        event.preventDefault();
        const index = tabs.indexOf(tab);
        const offset = event.key === "ArrowRight" ? 1 : -1;
        const next = tabs[(index + offset + tabs.length) % tabs.length];
        next.focus();
        activateJournal(next.getAttribute("data-tab-target"));
      });
    }

    searchInput?.addEventListener("input", applySearch);

    const hashKey = window.location.hash.replace("#", "").toUpperCase();
    if (tabs.some((tab) => tab.getAttribute("data-tab-target") === hashKey)) {
      activateJournal(hashKey, false);
    }
  </script>
</Layout>
